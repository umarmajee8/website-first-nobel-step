# ---- Google Sheets (membership submissions) ----
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Use real newlines or escape them as \n — the API unescapes automatically
GOOGLE_PRIVATE_KEY=

# ---- SMTP (Gmail app password used for verification codes + welcome emails) ----
SMTP_USER=
SMTP_PASS=

# ---- OTP secret (HMAC key for stateless verification codes) ----
# 32+ random bytes, e.g.  openssl rand -hex 32
# Falls back to a value derived from GOOGLE_PRIVATE_KEY if unset, but ALWAYS set this in production.
OTP_SECRET=

# ---- FastPay (PKR payment gateway) ----
# Leave blank for the simulated success flow used in dev.
FASTPAY_MERCHANT_ID=
FASTPAY_API_KEY=

# ---- Optional: allow-list of origins for API CORS (comma separated) ----
# e.g. https://firstnoblestep.com,https://www.firstnoblestep.com
ALLOWED_ORIGINS=
